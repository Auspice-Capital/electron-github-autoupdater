{
  "name": "electron-github-autoupdater",
  "version": "2.0.4",
  "description": "Use private or enterprise GitHub repositories to auto update Electron apps. A replacement for Electron's build-in autoUpdater.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "/dist"
  ],
  "scripts": {
    "build": "tsgo --build",
    "clean": "tsgo --build --clean",
    "format": "prettier --write ."
  },
  "repository": "https://github.com/christianblandford/electron-github-autoupdater",
  "author": "Christian Blandford",
  "license": "MIT",
  "private": false,
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/semver": "^7.5.1",
    "@typescript/native-preview": "^7.0.0-dev.20260427.1",
    "electron": "^16.0.4",
    "prettier": "^3.8.3"
  },
  "dependencies": {
    "@octokit/request": "^10.0.8",
    "electron-is-dev": "^2.0.0",
    "semver": "^7.5.4"
  }
}
